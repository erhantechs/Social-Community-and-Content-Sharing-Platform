# Copy this file to `.env` and fill the values for your environment.

# Django secret key — generate a fresh one for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Set to `false` in production
DJANGO_DEBUG=true

# Comma-separated list (no spaces). Use your real domains in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------- Email (optional in dev, required for prod password reset) ----------
# In dev, leave DJANGO_EMAIL_BACKEND unset to use the console backend (emails
# print to stdout). In production set it to SMTP and fill the rest:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-mailbox@example.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=SocialHub <noreply@yourdomain.com>
